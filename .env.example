# 복사해서 .env 로 저장 후 값 채우기 (cp .env.example .env). .env 는 커밋 제외됨.

# 슬랙 봇 토큰 (xoxb-...). 봇을 채널에 초대 + 읽기 권한
#   스코프: channels:history(공개) 또는 groups:history(비공개), channels:read
SLACK_BOT_TOKEN=xoxb-...
SLACK_CHANNEL_ID=C0B5H4AAN02

# 수집 루틴이 저장한 미디어 폴더 (기본: ./media)
MEDIA_DIR=./media

# (선택) 헤더 이미지 파일을 직접 지정
# HEADER_IMAGE_PATH=./media/2026-06-09_header.jpg

# (선택) 텔레그램 Bot API 토큰 — 이미지 다운로드 성공률 향상
# TELEGRAM_BOT_TOKEN=123456:ABC-...

# (선택) 링크드인 초안을 슬랙 DM으로 받을 경우 본인의 Slack 사용자 ID
# SLACK_DM_USER_ID=U0123456789

# (선택) 링크드인 초안에 들어갈 블로그 URL 생성용 (예: myblog → myblog.tistory.com)
# TISTORY_BLOG_NAME=myblog

# (선택) 카테고리 (기본: KOL리포트)
# TISTORY_CATEGORY=KOL리포트
